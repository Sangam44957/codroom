generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String              @id @default(cuid())
  name             String
  email            String              @unique
  password         String
  createdAt        DateTime            @default(now())
  emailVerified    Boolean             @default(false)
  resetOtp         String?
  resetOtpExpiry   DateTime?
  resetToken       String?             @unique
  resetTokenExpiry DateTime?
  verifyOtp        String?
  verifyOtpExpiry  DateTime?
  verifyToken      String?             @unique
  updatedAt        DateTime            @updatedAt
  pipelines        HiringPipeline[]
  templates        InterviewTemplate[]
  problems         Problem[]
  rooms            Room[]

  @@map("users")
}

model Room {
  id            String             @id @default(cuid())
  title         String
  status        String             @default("waiting")
  language      String             @default("javascript")
  candidateName String?
  createdAt     DateTime           @default(now())
  createdById   String
  problemId     String?
  joinToken     String             @unique @default(cuid())
  templateId    String?
  pipelineId    String?
  updatedAt     DateTime           @updatedAt
  messages      ChatMessage[]
  interview     Interview?
  problems      RoomProblem[]
  createdBy     User               @relation(fields: [createdById], references: [id])
  pipeline      HiringPipeline?    @relation(fields: [pipelineId], references: [id])
  problem       Problem?           @relation(fields: [problemId], references: [id])
  template      InterviewTemplate? @relation(fields: [templateId], references: [id])

  @@index([createdById, createdAt])
  @@index([pipelineId])
  @@map("rooms")
}

model RoomProblem {
  id        String  @id @default(cuid())
  order     Int     @default(0)
  roomId    String
  problemId String
  problem   Problem @relation(fields: [problemId], references: [id])
  room      Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, problemId])
  @@index([roomId, order])
  @@map("room_problems")
}

model Problem {
  id            String        @id @default(cuid())
  title         String
  description   String
  difficulty    String
  topic         String
  starterCode   String?
  testCases     Json?
  createdById   String?
  companies     String[]      @default([])
  estimatedTime Int?
  isPublic      Boolean       @default(false)
  usageCount    Int           @default(0)
  updatedAt     DateTime      @updatedAt
  createdBy     User?         @relation(fields: [createdById], references: [id])
  roomLinks     RoomProblem[]
  rooms         Room[]
  tags          Tag[]         @relation("ProblemToTag")

  @@index([difficulty, topic])
  @@map("problems")
}

model Tag {
  id       String    @id @default(cuid())
  name     String    @unique
  problems Problem[] @relation("ProblemToTag")

  @@map("tags")
}

model Interview {
  id        String            @id @default(cuid())
  finalCode String?
  language  String            @default("javascript")
  status    String            @default("in_progress")
  startedAt DateTime          @default(now())
  endedAt   DateTime?
  duration  Int?
  roomId    String            @unique
  updatedAt DateTime          @updatedAt
  report    AIReport?
  snapshots CodeSnapshot[]
  events    InterviewEvent[]
  notes     InterviewerNote[]
  room      Room              @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("interviews")
}

model CodeSnapshot {
  id          String    @id @default(cuid())
  code        String
  timestamp   DateTime  @default(now())
  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([interviewId, timestamp])
  @@map("code_snapshots")
}

model InterviewEvent {
  id          String    @id @default(cuid())
  type        String
  label       String
  timestamp   DateTime  @default(now())
  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([interviewId, timestamp])
  @@index([interviewId, type])
  @@map("interview_events")
}

model ChatMessage {
  id        String   @id @default(cuid())
  roomId    String
  sender    String
  role      String
  text      String
  timestamp DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, timestamp])
  @@map("chat_messages")
}

model InterviewerNote {
  id          String    @id @default(cuid())
  content     String
  createdAt   DateTime  @default(now())
  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@map("interviewer_notes")
}

model AIReport {
  id                   String    @id @default(cuid())
  correctness          Int
  codeQuality          Int
  timeComplexity       String
  spaceComplexity      String
  edgeCaseHandling     Int
  overallScore         Int
  recommendation       String
  summary              String
  improvements         String
  createdAt            DateTime  @default(now())
  interviewId          String    @unique
  shareToken           String?   @unique
  rubricProblemSolving Int       @default(0)
  rubricCommunication  Int       @default(0)
  rubricCodeQuality    Int       @default(0)
  rubricEdgeCases      Int       @default(0)
  rubricSpeed          Int       @default(0)
  shareTokenExpiresAt  DateTime?
  shareTokenRevokedAt  DateTime?
  updatedAt            DateTime  @updatedAt
  interview            Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@map("ai_reports")
}

model HiringPipeline {
  id          String             @id @default(cuid())
  name        String
  description String?
  status      PipelineStatus     @default(ACTIVE)
  targetHires Int                @default(1)
  createdById String
  templateId  String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  createdBy   User               @relation(fields: [createdById], references: [id])
  template    InterviewTemplate? @relation(fields: [templateId], references: [id])
  rooms       Room[]

  @@index([createdById, status])
  @@map("hiring_pipelines")
}

model InterviewTemplate {
  id               String           @id @default(cuid())
  name             String
  description      String?
  ownerId          String
  language         String           @default("javascript")
  durationMinutes  Int              @default(60)
  problemIds       String[]         @default([])
  focusModeEnabled Boolean          @default(false)
  rubricWeights    Json?
  customPrompt     String?
  usageCount       Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  pipelines        HiringPipeline[]
  owner            User             @relation(fields: [ownerId], references: [id])
  rooms            Room[]

  @@index([ownerId])
  @@map("interview_templates")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorEmail String?
  actorRole  String?
  action     String
  resource   String
  resourceId String
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([resource, resourceId])
  @@index([action, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

enum PipelineStatus {
  ACTIVE
  PAUSED
  CLOSED
}
