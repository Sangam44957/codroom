{
  "name": "codroom",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev --port 3000",
    "dev:socket": "node server/socket.mjs",
    "dev:all": "npx kill-port 3000 3001 && concurrently -k -r -n NEXT,SOCKET -c cyan,yellow \"npm run dev\" \"npm run dev:socket\"",
    "kill:ports": "npx kill-port 3000 3001",
    "start:clean": "npm run kill:ports && npm run dev:all",
    "build": "prisma generate && next build",
    "build:all": "prisma generate && next build",
    "build:docker": "docker build -t codroom-app -f Dockerfile.prod . && docker build -t codroom-socket -f Dockerfile.socket .",
    "start": "next start",
    "start:socket": "node server/socket.mjs",
    "start:all": "concurrently -k -r -n NEXT,SOCKET -c cyan,yellow \"npm run start\" \"npm run start:socket\"",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "jest --testPathPattern=e2e",
    "seed": "node prisma/seed.cjs",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "deploy:staging": "./scripts/deploy.sh staging",
    "deploy:production": "./scripts/deploy.sh production",
    "monitoring:up": "docker compose -f docker-compose.monitoring.yml up -d || docker-compose -f docker-compose.monitoring.yml up -d",
    "monitoring:down": "docker compose -f docker-compose.monitoring.yml down || docker-compose -f docker-compose.monitoring.yml down",
    "security:scan": "npm audit && docker run --rm -v $(pwd):/app securecodewarrior/docker-security-scan /app",
    "performance:test": "k6 run scripts/load-test.js",
    "backup:db": "pg_dump $DATABASE_URL | gzip > backup-$(date +%Y%m%d).sql.gz",
    "health:check": "curl -f $NEXT_PUBLIC_APP_URL/api/health"
  },
  "prisma": {
    "seed": "node prisma/seed.cjs"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transform": {
      "^.+\\.(js|jsx)$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(jose|next|@babel/runtime)/)"
    ],
    "setupFiles": [
      "<rootDir>/src/__tests__/setup.js"
    ]
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@prisma/client": "^5.22.0",
    "@sentry/nextjs": "^10.48.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.38.0",
    "groq-sdk": "^1.1.1",
    "jose": "^6.2.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.577.0",
    "next": "16.2.4",
    "peerjs": "^1.5.5",
    "pino": "^10.3.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@jest/globals": "^30.3.0",
    "@tailwindcss/postcss": "^4",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jest": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "kill-port": "^2.0.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "tailwindcss": "^4"
  }
}
